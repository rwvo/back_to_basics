10 MPI INIT
20 LET R = MPI RANK
30 LET S = MPI SIZE
40 DIM A(1), B(1)
50 LET A(1) = R * 100
60 LET DEST = R + 1
70 IF DEST >= S THEN LET DEST = 0
80 LET SRC = R - 1
90 IF SRC < 0 THEN LET SRC = S - 1
100 MPI SEND A TO DEST TAG 1
110 MPI RECV B FROM SRC TAG 1
120 IF R = 0 THEN PRINT B(1)
130 MPI FINALIZE
140 END
